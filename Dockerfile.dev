FROM golang:1.25-alpine

ENV GOTOOLCHAIN=auto

RUN apk add --no-cache git curl

# air — Go hot-reload (pin to avoid compatibility issues with Go version)
RUN go install github.com/air-verse/air@v1.61.0

WORKDIR /app

# Pre-download deps so rebuilds stay fast when only source changes
COPY go.mod go.sum ./
RUN go mod download

EXPOSE 8080

CMD ["air", "-c", ".air.toml"]
